// Séparateurs (espaces, retours à la ligne, commentaires)
WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT    = _{ "/*" ~ (!"*/" ~ ANY)* ~ "*/" | "//" ~ (!"\n" ~ ANY)* }

// Identifiants et Littéraux
ident = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }
hex_literal = @{ "0x" ~ ASCII_HEX_DIGIT+ }
bin_literal = @{ "0b" ~ ("0" | "1")+ }
oct_literal = @{ "0o" ~ ('0'..'7')+ }
dec_literal = @{ ASCII_DIGIT+ }
float_literal = @{ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT* ~ ("f" | "F") }
double_literal = @{ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT* ~ (("e" | "E") ~ ("+" | "-")? ~ ASCII_DIGIT+)? }
int_literal = @{ hex_literal | bin_literal | oct_literal | dec_literal }
bool_literal = @{ "true" | "false" }
string_literal = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" }
char_literal = @{ "'" ~ (!"'" ~ ANY)* ~ "'" }

// Types primitifs
type_ident = { "int" | "uint" | "long" | "float" | "double" | "ulong" | "byte" | "string" | "bool" | "void" }

// Keywords
async_keyword = { "async" }
await_keyword = { "await" }
new_keyword = { "new" }

// Operators
arith_op = { "+" | "-" | "*" | "/" | "%" }
bitwise_op = { "&" | "|" | "^" | "<<" | ">>" }
logical_op = { "&&" | "||" }
comparison_op = { "<=" | ">=" | "<" | ">" | "==" | "!=" }
assignment_op = { "=" | "+=" | "-=" }
increment_op = { "++" | "--" }

// Expressions - simplified for clarity
unary_op = { "+" | "-" | "!" }

primary = {
    bool_literal
    | float_literal
    | double_literal
    | int_literal
    | string_literal
    | char_literal
    | "(" ~ expr ~ ")"
    | ident
}

unary = {
    unary_op? ~ primary ~ (
        "(" ~ (expr ~ ("," ~ expr)*)? ~ ")"    // Function call
        | "[" ~ expr ~ "]"                      // Array access
        | "." ~ ident                           // Member access
    )*
}

postfix = {
    unary ~ (
        "(" ~ (expr ~ ("," ~ expr)*)? ~ ")"    // Function call
        | "[" ~ expr ~ "]"                      // Array access
        | "." ~ ident                           // Member access
    )*
}

expr = { postfix ~ ((arith_op | bitwise_op | logical_op | comparison_op) ~ postfix)* }

new_expr = {
    new_keyword ~ ident ~ "(" ~ (expr ~ ("," ~ expr)*)? ~ ")"
}

// Déclaration de constante
const_decl = { "const" ~ type_ident ~ ident ~ "=" ~ expr ~ ";" }

// Déclaration de variable
variable_decl = { 
    (type_ident | ident) ~ ident ~ ("=" ~ (new_expr | expr))? ~ ";"
}

parameter = { (type_ident | ident) ~ ident }
param_list = { parameter ~ ("," ~ parameter)* }

function_body = _{ "=>" ~ (block | statement) | block }

function = {
    !"class" ~ !"struct" ~ "public"? ~ "static"? ~ "private"? ~ async_keyword? ~ (type_ident | ident) ~ ident ~ "(" ~ param_list? ~ ")" ~ function_body
}

block = { "{" ~ statement* ~ "}" }

// Size expression
size_expr = { int_literal ~ (("*" | "+") ~ int_literal)* }

// Array declaration
array_decl = { (type_ident | ident) ~ "[" ~ size_expr ~ "]" ~ ident ~ ";" }

// Array access statement
array_access = { ident ~ "[" ~ expr ~ "]" }

// Attribute
attribute = { "[" ~ ident ~ ("(" ~ int_literal ~ ")")? ~ "]" }

// Struct field
struct_field = { (type_ident | ident) ~ ("[" ~ size_expr ~ "]")? ~ ident ~ ";" }

struct_def = {
    attribute? ~ "public"? ~ "static"? ~ "private"? ~ "struct" ~ ident ~ "{" ~ struct_field* ~ "}"
}

// Class definition
class_property = { ("public" | "private")? ~ (type_ident | ident) ~ ("[" ~ size_expr ~ "]")? ~ ident ~ ("=" ~ expr)? ~ ";" }
class_method = { ("public" | "private")? ~ async_keyword? ~ (type_ident | ident) ~ ident ~ "(" ~ param_list? ~ ")" ~ function_body }
class_constructor = { "public" ~ ident ~ "(" ~ param_list? ~ ")" ~ function_body }

class_def = {
    attribute? ~ "public"? ~ "static"? ~ "private"? ~ "class" ~ ident ~ (":" ~ ident)? ~ "{" ~ (class_property | class_method | class_constructor)* ~ "}"
}

// Condition 
condition = { "(" ~ expr ~ ")" }

increment = { ident ~ ("++" | "--" | (assignment_op ~ expr)) }
increment_stmt = { ident ~ increment_op ~ ";" }

assignment_stmt = { (ident ~ ("." ~ ident)? | array_access) ~ assignment_op ~ expr ~ ";" }

for_init = { (type_ident | ident) ~ ident ~ ("=" ~ expr)? }

for_loop = {
    "for" ~ "(" ~ for_init ~ ";" ~ condition ~ ";" ~ increment ~ ")" ~ block
}

while_loop = {
    "while" ~ "(" ~ condition ~ ")" ~ block
}

else_part = { "else" ~ (if_stmt | block) }
if_stmt = {
    "if" ~ "(" ~ condition ~ ")" ~ block ~ else_part?
}

return_stmt = { "return" ~ expr? ~ ";" }
break_stmt = { "break" ~ ";" }
continue_stmt = { "continue" ~ ";" }

// Function call statement
function_call = { ident ~ ("." ~ ident)? ~ "(" ~ (expr ~ ("," ~ expr)*)? ~ ")" ~ ";" }

// Await statement
await_stmt = { await_keyword ~ ident ~ "(" ~ (expr ~ ("," ~ expr)*)? ~ ")" ~ ";" }

// Statement rule
statement = _{
    for_loop
    | while_loop
    | if_stmt
    | return_stmt
    | break_stmt
    | continue_stmt
    | await_stmt
    | const_decl
    | variable_decl
    | array_decl
    | increment_stmt
    | assignment_stmt
    | function_call
}

// File root - Only classes and structs allowed (no global functions)
file = { SOI ~ (const_decl | struct_def | class_def)* ~ EOI }

public static void Main() {
    float x = 3.14f;
    double y = 2.71828;
    
    float sum_f = 1.5f + 2.5f;
    double sum_d = 1.5 + 2.5;
    
    float product = 3.0f * 2.0f;
    double division = 10.0 / 3.0;
    
    print(x);
    print(y);
    print(sum_f);
    print(sum_d);
    print(product);
    print(division);
}


/* FluxSharp - Arrays Example */

public static void Main() {
    int[10] numbers;
    
    numbers[0] = 10;
    numbers[1] = 20;
    numbers[2] = 30;
    numbers[3] = 40;
    numbers[4] = 50;
    
    print("Arrays Example");
    
    int first = numbers[0];
    int second = numbers[1];
    int third = numbers[2];
    
    print("Array elements stored and accessed");
    
    return;
}


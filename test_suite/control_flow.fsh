public class Main {
    public void main() {
        int x = 5;
        if (x > 0) {
            print("Positive");
        } else {
            print("Non-positive");
        }
        
        for (int i = 0; i < 3; i = i + 1) {
            print("Loop");
        }
        
        print("✅ Control flow: PASS");
    }
}
